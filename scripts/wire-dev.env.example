# path-graph wire-dev — local port map after: ./scripts/wire-dev.sh up
#
# agents-runtime (namespace runtime):
#   postgres     127.0.0.1:5432  → svc/postgres:5432
#   envoy        127.0.0.1:8084  → svc/envoy:8080
#   auth         127.0.0.1:8081  → svc/auth:8080
#   garage-s3    127.0.0.1:3900  → svc/garage-s3:3900  (profile s3)
#
# test_infra:
#   qdrant       127.0.0.1:6333  → qdrant/svc/qdrant:6333
#   nebula       127.0.0.1:9669  → nebula/svc/nebula-graphd-svc:9669
#
# llm-serving (embedding TEI, optional port-forward):
#   bge-m3-tei   127.0.0.1:8085  → llm-serving/svc/bge-m3-tei:8080
#
# Generate .env.dev.local:
#   ./scripts/wire-dev.sh env
#   ./scripts/wire-dev.sh env --storage s3   # Garage blob mode
#
# Agent JWT (optional):
#   WIRE_DEV_AUTH_USER=admin WIRE_DEV_AUTH_PASSWORD=... ./scripts/wire-dev.sh env
