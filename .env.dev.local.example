# path-graph local dev — copy to .env.dev.local or run: ./scripts/wire-dev.sh env
# Do not commit .env.dev.local (.gitignore)

ENV=dev
LOG_LEVEL=DEBUG
PATH_GRAPH_TENANT=dev

# runtime PG (wire-dev → postgres :5432)
PATH_GRAPH_DSN=postgresql://runtime:runtime@127.0.0.1:5432/runtime?sslmode=disable

# blob — local (default) or s3 via: ./scripts/wire-dev.sh env --storage s3
PIPELINE_STORAGE_BACKEND=local
PIPELINE_STORAGE_DIR=.data/pipeline
# S3_ENDPOINT_URL=http://127.0.0.1:3900
# S3_BUCKET=path-graph
# S3_ACCESS_KEY=
# S3_SECRET_KEY=

# test_infra (wire-dev → qdrant :6333, nebula :9669) — owned by path-graph deploy/k8s/infra/
QDRANT_URL=http://127.0.0.1:6333
QDRANT_API_KEY=

NEBULA_HOST=127.0.0.1
NEBULA_PORT=9669
NEBULA_USER=root
NEBULA_PASSWORD=nebula

# agents-runtime invoke (wire-dev → envoy :8084)
ENVOY_URL=http://127.0.0.1:8084
PIPELINE_AGENT_ACCESS_TOKEN=

# RAG embed — cluster 내부 URL. 로컬 TEI PF 시:
#   kubectl -n llm-serving port-forward svc/bge-m3-tei 8085:8080
#   EMBEDDING_BASE_URL=http://127.0.0.1:8085
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIM=1024
EMBEDDING_BASE_URL=http://bge-m3-tei.llm-serving.svc.cluster.local:8080

# HWP parser (rhwp_batch)
RHWP_BATCH_BIN=rhwp-batch

# OAuth collectors (optional)
# MS_TENANT_ID=
# MS_CLIENT_ID=
# MS_CLIENT_SECRET=
# MS_REFRESH_TOKEN=
# MS_AUTH_MODE=app
# GDRIVE_CLIENT_ID=
# GDRIVE_CLIENT_SECRET=
# GDRIVE_REFRESH_TOKEN=
# ONEDRIVE_REFRESH_TOKEN=
